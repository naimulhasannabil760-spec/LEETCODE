#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;
int main()
{
    vector<int>nums={1,2,4,4,4,4,4,3,5};

    sort(nums.begin(),nums.end());
    int freq=1,ans=nums[0];
    int n = nums.size();
    for(int i=1;i<n;i++)
    {
        if(nums[i]==nums[i-1])
        {
            freq++;
        }
        else
        {
            freq=1;
            ans = nums[i];
        }
        if(freq>n/2)
        {
            cout << ans;
            return ans;
            break;
        }
    }
    cout << "No majority element";
    return 0;
}
